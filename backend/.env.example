# Backend configuration
FRONTEND_ORIGIN=http://localhost:3000
SIMULATION_ONLY=true

# Choose one main AI provider for analysis, coaching, debriefs, and Knowledge
# Lab. The checked-in default below uses Anthropic for the main AI stack and
# OpenAI for transcription.
#
# Use the generic AI_* variables for the main provider. Do not mix
# AI_API_KEY with OPENAI_API_KEY or ANTHROPIC_API_KEY in the same setup unless
# you are intentionally testing env alias behavior.

# Default main AI setup: local vLLM on localhost
AI_PROVIDER=openai
AI_API_BASE_URL=http://127.0.0.1:8000/v1
AI_API_KEY=local-vllm-key
AI_ANALYSIS_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
AI_DEBRIEF_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
AI_COACH_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
AI_LEARNING_MODEL=Qwen/Qwen2.5-VL-3B-Instruct

# Optional Anthropic fallback when the local model server is not reachable or
# not loaded. Add the real fallback key only if you want cloud fallback.
AI_FALLBACK_PROVIDER=anthropic
AI_FALLBACK_API_BASE_URL=https://api.anthropic.com/v1/messages
AI_FALLBACK_API_KEY=SET_IN_ENV_MANAGER
AI_FALLBACK_ANALYSIS_MODEL=claude-sonnet-4-6
AI_FALLBACK_DEBRIEF_MODEL=claude-sonnet-4-6
AI_FALLBACK_COACH_MODEL=claude-sonnet-4-6
AI_FALLBACK_LEARNING_MODEL=claude-haiku-4-5

# Request tuning
AI_TIMEOUT_SECONDS=60
AI_ANALYSIS_MAX_TOKENS=1400
AI_DEBRIEF_MAX_TOKENS=1200
AI_SAFETY_MAX_TOKENS=600
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.78
GRADING_CONFIDENCE_THRESHOLD=0.80

# Anthropic request header version
ANTHROPIC_VERSION=2023-06-01

# Dedicated transcription provider. This build expects an OpenAI-compatible
# transcription endpoint here. If you use OpenAI as the main provider too, you
# may reuse the same OpenAI key value in both AI_API_KEY and
# TRANSCRIPTION_API_KEY.
TRANSCRIPTION_API_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_API_KEY=SET_IN_ENV_MANAGER
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_TIMEOUT_SECONDS=60

# Optional private team-only seeded accounts.
# Keep this in your host secret manager, not in source control.
# Example:
# PRIVATE_SEED_ACCOUNTS_JSON=[{"id":"account-developer-team","name":"Developer Team","username":"developer@example.com","password":"SET_IN_ENV_MANAGER","role":"admin","is_developer":true,"live_session_limit":null}]
